# LLM CONNECTION
#=============================================================
OPENAI_API_BASE=<FILL_IN>
MODEL_MAIN=<FILL_IN>
MODEL_CHEAP=<FILL_IN>

# Client-credentials OAuth2 flow. When OAUTH_TOKEN_URL is set, the app
# fetches a fresh bearer token at startup and refreshes it before expiry,
# overriding OPENAI_API_KEY in-process. Leave OAUTH_TOKEN_URL unset to
# fall back to a hand-pasted static OPENAI_API_KEY below.
OAUTH_TOKEN_URL=<FILL_IN>
OAUTH_CLIENT_ID=<FILL_IN>
OAUTH_CLIENT_SECRET=<FILL_IN>
OAUTH_SCOPE=<FILL_IN>

# Static fallback (used only when OAUTH_TOKEN_URL is empty).
# OPENAI_API_KEY=<FILL_IN>


# App config
SESSIONS_DIR=./sessions
TEMPLATE_PATH=./templates/Automation_SDD_template.docx
MERMAID_CLI=mmdc
BOT_CONTROLLER_EMAIL=
